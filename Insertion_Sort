<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<title>插入排序動畫</title>
<style>
    body {
        text-align: center;
        font-family: Arial;
    }

    #container {
        display: flex;
        justify-content: center;
        align-items: flex-end;
        height: 300px;
        margin-top: 20px;
    }

    .bar {
        width: 20px;
        margin: 2px;
        background-color: steelblue;
    }

    .active {
        background-color: red;
    }

    .key {
        background-color: orange;
    }

    .sorted {
        background-color: green;
    }

    button {
        margin: 10px;
        padding: 10px 20px;
    }
</style>
</head>

<body>

<h2>插入排序動畫（Insertion Sort）</h2>

<button onclick="generateArray()">重新生成</button>
<button onclick="insertionSort()">開始排序</button>

<div id="container"></div>

<script>
let array = [];
let container = document.getElementById("container");

function generateArray() {
    container.innerHTML = "";
    array = [];

    for (let i = 0; i < 30; i++) {
        let value = Math.floor(Math.random() * 250) + 10;
        array.push(value);

        let bar = document.createElement("div");
        bar.classList.add("bar");
        bar.style.height = value + "px";

        container.appendChild(bar);
    }
}

async function insertionSort() {
    let bars = document.getElementsByClassName("bar");

    for (let i = 1; i < array.length; i++) {
        let key = array[i];
        let j = i - 1;

        bars[i].classList.add("key");
        await sleep(80);

        while (j >= 0 && array[j] > key) {
            bars[j].classList.add("active");

            array[j + 1] = array[j];
            bars[j + 1].style.height = array[j] + "px";

            await sleep(80);

            bars[j].classList.remove("active");
            j--;
        }

        array[j + 1] = key;
        bars[j + 1].style.height = key + "px";

        bars[i].classList.remove("key");

        // 標記已排序區
        for (let k = 0; k <= i; k++) {
            bars[k].classList.add("sorted");
        }
    }
}

function sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
}

// 初始化
generateArray();
</script>

</body>
</html>
