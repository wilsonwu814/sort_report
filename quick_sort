<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<title>快速排序動畫</title>
<style>
    body {
        text-align: center;
        font-family: Arial;
    }

    #container {
        display: flex;
        justify-content: center;
        align-items: flex-end;
        height: 300px;
        margin-top: 20px;
    }

    .bar {
        width: 20px;
        margin: 2px;
        background-color: steelblue;
        transition: 0.2s;
    }

    .active {
        background-color: red;
    }

    .pivot {
        background-color: orange;
    }

    .sorted {
        background-color: green;
    }

    button {
        margin: 10px;
        padding: 10px 20px;
    }
</style>
</head>

<body>

<h2>快速排序動畫（Quick Sort）</h2>

<button onclick="generateArray()">重新生成</button>
<button onclick="quickSortStart()">開始排序</button>

<div id="container"></div>

<script>
let array = [];
let container = document.getElementById("container");

function generateArray() {
    container.innerHTML = "";
    array = [];

    for (let i = 0; i < 30; i++) {
        let value = Math.floor(Math.random() * 250) + 10;
        array.push(value);

        let bar = document.createElement("div");
        bar.classList.add("bar");
        bar.style.height = value + "px";

        container.appendChild(bar);
    }
}

// 交換
function swap(i, j, bars) {
    let temp = array[i];
    array[i] = array[j];
    array[j] = temp;

    bars[i].style.height = array[i] + "px";
    bars[j].style.height = array[j] + "px";
}

function sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
}

async function partition(low, high, bars) {
    let pivot = array[high];
    bars[high].classList.add("pivot");

    let i = low - 1;

    for (let j = low; j < high; j++) {
        bars[j].classList.add("active");

        await sleep(80);

        if (array[j] < pivot) {
            i++;
            swap(i, j, bars);
        }

        bars[j].classList.remove("active");
    }

    swap(i + 1, high, bars);

    bars[high].classList.remove("pivot");

    return i + 1;
}

async function quickSort(low, high, bars) {
    if (low < high) {
        let pi = await partition(low, high, bars);

        await quickSort(low, pi - 1, bars);
        await quickSort(pi + 1, high, bars);
    }
}

async function quickSortStart() {
    let bars = document.getElementsByClassName("bar");

    await quickSort(0, array.length - 1, bars);

    // 標記完成
    for (let i = 0; i < bars.length; i++) {
        bars[i].classList.add("sorted");
    }
}

// 初始化
generateArray();
</script>

</body>
</html>
